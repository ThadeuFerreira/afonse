{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "REST API (FastAPI via uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "music_teacher_ai.api.rest_api:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": false
    },
    {
      "name": "REST API (init --quick then uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "music_teacher_ai.api.rest_api:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000",
        "--reload"
      ],
      "preLaunchTask": "music-teacher: init --quick",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": false
    },
    {
      "name": "Debug: music-teacher init --quick",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/.venv/bin/music-teacher",
      "args": [
        "init",
        "--quick"
      ],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "MCP Server (stdio JSON tools)",
      "type": "python",
      "request": "launch",
      "module": "music_teacher_ai.api.mcp_server",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
