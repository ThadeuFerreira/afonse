{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "music-teacher: init --quick",
      "type": "shell",
      "command": "uv run music-teacher init --quick",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "uvicorn: rest_api (no reload)",
      "type": "shell",
      "command": "uv run uvicorn music_teacher_ai.api.rest_api:app --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "uvicorn: rest_api (--reload)",
      "type": "shell",
      "command": "uv run uvicorn music_teacher_ai.api.rest_api:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "python -m music_teacher_ai.api.mcp_server",
      "type": "shell",
      "command": "uv run python -m music_teacher_ai.api.mcp_server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
