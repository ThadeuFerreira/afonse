    {
      "name": "Search",
      "item": [
        {
          "name": "Search – list songs (no filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/songs",
              "host": ["{{base_url}}"],
              "path": ["songs"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Search – keyword (saves song_id)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?word=dream",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [{"key": "word", "value": "dream"}]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has results wrapper', function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('results');",
                  "    pm.expect(data.results).to.be.an('array');",
                  "    pm.expect(data).to.have.property('database_expansion_triggered');",
                  "    pm.expect(data.database_expansion_triggered).to.be.a('boolean');",
                  "});",
                  "pm.test('Each result has required fields', function () {",
                  "    const payload = pm.response.json();",
                  "    const data = payload.results;",
                  "    if (data.length > 0) {",
                  "        const song = data[0];",
                  "        pm.expect(song).to.have.property('id');",
                  "        pm.expect(song).to.have.property('title');",
                  "        pm.expect(song).to.have.property('artist');",
                  "    }",
                  "});",
                  "// Save first song_id for downstream tests",
                  "const data = pm.response.json().results;",
                  "if (data.length > 0) {",
                  "    pm.environment.set('song_id', data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Search – year range filter",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?year_min=1980&year_max=1989",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                {"key": "year_min", "value": "1980"},
                {"key": "year_max", "value": "1989"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('All results are within year range', function () {",
                  "    const payload = pm.response.json();",
                  "    pm.expect(payload).to.have.property('results');",
                  "    const data = payload.results;",
                  "    data.forEach(function(song) {",
                  "        if (song.year !== null) {",
                  "            pm.expect(song.year).to.be.within(1980, 1989);",
                  "        }",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Search – semantic query",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"query\": \"songs about freedom and hope\", \"top_k\": 5}"
